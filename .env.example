# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# ==============================================================================
# Configurações da Aplicação
# ==============================================================================

# Porta do servidor (padrão: 8000)
PORT=8000

# Host (0.0.0.0 para aceitar conexões externas)
HOST=0.0.0.0

# Número de workers Gunicorn
WORKERS=4

# Ambiente (development | production)
ENVIRONMENT=production

# Chave secreta (altere em produção!)
SECRET_KEY=leao-triste-secret-key-change-in-production

# Tamanho máximo de upload (bytes) — padrão 100MB
MAX_UPLOAD_SIZE=104857600
